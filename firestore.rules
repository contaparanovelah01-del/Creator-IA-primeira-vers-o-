rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    function isAdmin() {
      return isSignedIn() && 'email' in request.auth.token && request.auth.token.email != null && 
             request.auth.token.email == 'victormizael09@gmail.com';
    }

    function isValidGeneration(data) {
      return data.keys().hasAll(['userId', 'topic', 'content', 'type', 'platform', 'tone', 'language', 'isFavorite', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.topic is string &&
             data.content is string &&
             data.type is string &&
             data.platform is string &&
             data.tone is string &&
             data.language is string &&
             data.isFavorite is bool &&
             (!data.keys().hasAny(['scriptType']) || data.scriptType is string) &&
             data.userId == request.auth.uid; // Identity Integrity
    }

    match /generations/{generationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      allow create: if isSignedIn() &&
                    isValidGeneration(incoming()) &&
                    incoming().createdAt == request.time &&
                    (incoming().keys().size() == 9 || incoming().keys().size() == 10);

      allow update: if isOwner(existing().userId) && 
                    // Only allow updating the isFavorite field
                    incoming().diff(existing()).affectedKeys().hasOnly(['isFavorite']) &&
                    incoming().isFavorite is bool &&
                    incoming().userId == existing().userId; // Immutability

      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && (isOwner(incoming().userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(existing().userId) || isAdmin()) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && (!incoming().keys().hasAny(['banned', 'plan']) || (incoming().get('banned', false) == existing().get('banned', false) && incoming().get('plan', 'free') == existing().get('plan', 'free')))) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
