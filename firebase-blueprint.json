{
  "entities": {
    "Generation": {
      "title": "Generation",
      "description": "A piece of content generated by the user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who created this."
        },
        "topic": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "tone": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "scriptType": {
          "type": "string"
        },
        "isFavorite": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "topic", "content", "type", "platform", "tone", "language", "isFavorite", "createdAt"]
    }
  },
  "firestore": {
    "generations/{generationId}": {
      "schema": "Generation",
      "description": "Generated content by users."
    }
  }
}
